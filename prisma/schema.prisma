generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id           Int     @id @default(autoincrement())
  nummer       String  @unique // bijv. "1100"
  naam         String // bijv. "Bank"
  type         String // "actief" | "passief" | "kosten" | "opbrengsten"
  systeem      Boolean @default(false) // true = niet verwijderbaar (BTW-rekeningen)
  openingSaldo Float   @default(0) // natural balance: positief = normale kant van de rekening
}

model Transaction {
  id            String             @id @default(cuid())
  datum         String // "YYYY-MM-DD"
  omschrijving  String
  factuurNummer String?
  btwGrondslag  Float? // excl. BTW bedrag
  btwBedrag     Float?
  btwCode       String? // "21" | "9" | "0"
  btwRichting   String? // "vordering" | "afdracht"
  regels        TransactionRegel[]
  createdAt     DateTime           @default(now())
}

model TransactionRegel {
  id            Int         @id @default(autoincrement())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  rekening      String // rekeningnummer
  debet         Float       @default(0)
  credit        Float       @default(0)
}

model Setting {
  key   String @id
  value String
}
