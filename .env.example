# Kopieer naar .env en vul in. Zowel de app (dotenv) als de Prisma CLI lezen dit bestand.
DATABASE_URL="file:./boekhouding.db"
ANTHROPIC_API_KEY="sk-ant-..."
ADMIN_PASSWORD="kies-een-sterk-wachtwoord"
# Geheim voor het ondertekenen van de sessiecookie (maak dit lang en willekeurig)
SESSION_SECRET="verander-dit-in-iets-willekeurigs"
# In productie (cPanel): zorgt voor secure cookies en productie-instellingen.
NODE_ENV="production"
# PORT wordt op cPanel door Passenger geleverd; lokaal standaard 3000.
PORT=3000
