# BV Boekhouding — Apache/LiteSpeed (draait in submap /boekhouding)
DirectoryIndex index.html

# Blokkeer directe toegang tot gevoelige bestanden.
<FilesMatch "^(config.*\.php|.*\.sql|\.cpanel\.yml)$">
  Require all denied
</FilesMatch>

# Blokkeer directe toegang tot de includes-map (server-side ge-include),
# ook onder een submap-pad.
RedirectMatch 403 (^|/)includes/
